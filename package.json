{
  "name": "@voidmerge/jserde",
  "version": "0.0.1",
  "description": "Typescript streaming serializer and deserializer.",
  "license": "(MIT or Apache-2.0)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/voidmerge/jserde"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "fmt": "prettier . --write",
    "buildFull": "npm run doc && npm run fmt && tsc --build",
    "build": "npm run doc && npm run fmt && tsc --build",
    "test": "npm run build && vitest run",
    "doc": "rimraf ./*.md && typedoc"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {}
}
